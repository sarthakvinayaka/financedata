# ─────────────────────────────────────────────
# JoinSafe — Environment Variables
# Copy to .env and fill in values.
# Never commit .env to version control.
# ─────────────────────────────────────────────

# ── Database ─────────────────────────────────
# Local: postgresql://postgres:postgres@localhost:5432/joinsafe
# Supabase: found in Project Settings > Database > URI (Transaction mode)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/joinsafe"

# ── App ──────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="JoinSafe"

# ── Auth (NextAuth.js) ────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# OAuth providers (add as needed)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# ── Stripe (payments) ────────────────────────
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ── SEC EDGAR ────────────────────────────────
# Required by EDGAR: identifies your application in User-Agent header
# Format: "YourApp/1.0 contact@yourcompany.com"
SEC_EDGAR_USER_AGENT="JoinSafe/1.0 contact@joinsafe.com"

# ── Worker ───────────────────────────────────
# Cron expressions for background jobs (default: daily at 2am)
WORKER_CRON_INGEST_SEC="0 2 * * *"
WORKER_CRON_INGEST_WARN="0 3 * * *"
WORKER_CRON_SCORE_RECOMPUTE="0 4 * * *"

# Batch size for ingestion jobs
INGEST_BATCH_SIZE="50"

# ── Logging ──────────────────────────────────
LOG_LEVEL="info"

# ── Feature flags ────────────────────────────
ENABLE_SIGNUP="true"
ENABLE_PRO_PLAN="false"

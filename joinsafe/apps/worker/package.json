{
  "name": "@joinsafe/worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "ingest:sec": "tsx src/jobs/ingest-sec.ts",
    "ingest:warn": "tsx src/jobs/ingest-warn.ts",
    "score:recompute": "tsx src/jobs/score-recompute.ts",
    "ingest:company": "tsx src/commands/ingest-company.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@joinsafe/core": "workspace:*",
    "@joinsafe/db": "workspace:*",
    "@joinsafe/providers": "workspace:*",
    "node-cron": "^3.0.3",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  }
}

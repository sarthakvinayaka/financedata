// ENUMS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

enum CompanyType {
  PUBLIC
  PRIVATE
}

enum AliasType {
  FORMER_NAME
  DBA
  ABBREVIATION
  TICKER
  TRADE_NAME
}

enum DataQuality {
  LOW    // Name-only match; no verified external identifiers
  MEDIUM // Partial coverage — WARN only, or SEC only
  HIGH   // Verified CIK/ticker, matched WARN records, recent data
}

enum LayoffSourceType {
  WARN         // U.S. WARN Act state filing
  SEC_FILING   // Disclosed in 10-K, 10-Q, or 8-K
  NEWSROOM     // Official company blog or press room
  PRESS        // Third-party news outlet
  MANUAL       // Human-entered record
}

enum LayoffReason {
  COST_CUTTING
  RESTRUCTURING
  DEMAND_SLOWDOWN
  POST_MERGER_INTEGRATION
  PRODUCT_SHIFT
  AI_SHIFT
  FACILITY_CLOSURE
  PROFITABILITY_PUSH
  FUNDING_PRESSURE
  UNKNOWN
}

enum ConfidenceLabel {
  REPORTED   // Directly stated in a primary source
  DERIVED    // Calculated from primary data via documented formula
  ESTIMATED  // Approximated from partial data; margin of uncertainty applies
  INFERRED   // Reasoned from indirect signals; lowest confidence
  UNKNOWN    // Source could not be determined
}

enum SourceDocumentType {
  WARN_NOTICE
  SEC_10K
  SEC_10Q
  SEC_8K
  NEWS_ARTICLE
  PRESS_RELEASE
  MANUAL_ENTRY
}

enum RiskBand {
  LOW     // Score 0–33
  MEDIUM  // Score 34–66
  HIGH    // Score 67–100
}

enum SignalCategory {
  WARN
  SEC
  FINANCIAL
  MOMENTUM
}

enum SignalSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NewsSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum AlertType {
  BAND_CHANGE      // Risk band changed (e.g. LOW → HIGH)
  SCORE_SPIKE      // Score increased by > threshold in one period
  NEW_LAYOFF       // New LayoffEvent created for watched company
  GOING_CONCERN    // Going concern opinion filed
  WATCHLIST_DIGEST // Periodic summary digest
}

enum ReportType {
  COMPANY_PROFILE   // Full company risk report
  RISK_DEEP_DIVE    // Signal-by-signal analysis
  COMPARISON        // Side-by-side company comparison
}

enum ReportStatus {
  PENDING
  GENERATING
  READY
  FAILED
  EXPIRED
}

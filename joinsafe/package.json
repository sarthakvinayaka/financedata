{
  "name": "joinsafe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "typecheck": "turbo typecheck",
    "db:migrate": "pnpm --filter @joinsafe/db exec prisma migrate dev",
    "db:migrate:prod": "pnpm --filter @joinsafe/db exec prisma migrate deploy",
    "db:seed": "pnpm --filter @joinsafe/db seed",
    "db:studio": "pnpm --filter @joinsafe/db exec prisma studio",
    "db:generate": "pnpm --filter @joinsafe/db exec prisma generate",
    "ingest:sec": "pnpm --filter @joinsafe/worker ingest:sec",
    "ingest:warn": "pnpm --filter @joinsafe/worker ingest:warn",
    "score:recompute": "pnpm --filter @joinsafe/worker score:recompute"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "turbo": "^2.1.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
